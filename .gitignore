# ================================================
# AI Perfumery System — .gitignore
# ================================================

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ===== Virtual Environment =====
server/openpom_env/
venv/
env/
.venv/

# ===== Model Weights =====
# 모델 가중치는 Git LFS로 관리 (검증용)
*.onnx
*.safetensors

# ===== Large Data Files =====
server/data/pom_data/pyrfume_all/
server/data/pom_data/pyrfume_labels/
server/data/pom_upgrade/new_embeddings_138d.json
*.csv.gz
*.tar.gz

# ===== IDE =====
.idea/
.vscode/
*.swp
*.swo
*~

# ===== OS =====
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ===== Logs & Temp =====
*.log
/tmp/
.tmp/
npm-debug.log*

# ===== Node (if any frontend deps) =====
node_modules/
package-lock.json

# ===== Docker =====
docker-compose.override.yml

# ===== Secrets =====
.env
.env.local
*.key
*.pem

# ===== Gemini/Antigravity Agent =====
.gemini/
.agent/
